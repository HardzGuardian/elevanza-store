# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-random-32-char-secret-here

# ─── App URL ───────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://elevanza-store.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# For local testing use: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: Cloudinary Dashboard → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Create an unsigned upload preset in: Cloudinary Dashboard → Settings → Upload → Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─── Supabase (optional, if using Supabase client directly) ───────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
